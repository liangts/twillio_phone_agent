OPENAI_API_KEY=sk-...
OPENAI_WEBHOOK_SECRET=whsec-...
OPENAI_MODEL=gpt-realtime
OPENAI_VOICE=alloy
CF_INGEST_BASE_URL=
CF_INGEST_TOKEN=
PROMPT_PATH=./config/agent_prompt.md
# Inbound-only welcome line spoken when the realtime socket opens.
WELCOME_MESSAGE=Thanks for calling. How can I help you?
PORT=3000
WS_CONNECT_DELAY_MS=250
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
HUMAN_AGENT_NUMBER=
TWILIO_HUMAN_LABEL=human agent
TWILIO_OUTBOUND_FROM=
OPENAI_SIP_URI=
TWILIO_OUTBOUND_STATUS_CALLBACK_URL=
CONTROL_API_TOKEN=
DISCORD_WEBHOOK_URL=
INPUT_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
INPUT_TRANSCRIPTION_LANGUAGE=en
OPENAI_INPUT_NOISE_REDUCTION=near_field
OPENAI_TURN_DETECTION_THRESHOLD=0.70
OPENAI_TURN_DETECTION_PREFIX_PADDING_MS=300
OPENAI_TURN_DETECTION_SILENCE_DURATION_MS=700
OPENAI_TURN_DETECTION_INTERRUPT_RESPONSE=true
OPENAI_TURN_DETECTION_CREATE_RESPONSE=true
